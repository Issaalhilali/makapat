# ──────────────────────────────────────────────────────────────────────────
#  Nabih × Muk3bat — environment configuration
#  Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# ──────────────────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000

# ── AI backend (Claude API) ────────────────────────────────────────────────
# Get a key from https://console.anthropic.com . If left blank, the assistant
# automatically falls back to the built-in mock engine (useful for demos).
ANTHROPIC_API_KEY=
# Model id — keep claude-opus-4-8 unless you have a reason to change it.
ANTHROPIC_MODEL=claude-opus-4-8

# ── Reverse proxy (development simulation only) ─────────────────────────────
# The live store the dev proxy mirrors onto localhost.
PROXY_TARGET=https://muk3bat.com

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of origins allowed to call /api/nabih-chat.
# In production this is the store's real domain(s).
ALLOWED_ORIGINS=https://muk3bat.com,https://www.muk3bat.com,http://localhost:3000

# ── Persistence (optional — wire up when you add chat logging / analytics) ──
DATABASE_URL=

# ── Conversion / marketing (mock promotional triggers for pricing replies) ──
# Set NABIH_PROMO=false to disable the coupon + scarcity nudges in production.
NABIH_PROMO=true
NABIH_PROMO_CODE=NABIH10

# ── Contact channels (shown as buttons in Nabih's contact card) ─────────────
NABIH_WHATSAPP=https://wa.me/966555991437
NABIH_WHATSAPP_DISPLAY=0555991437
NABIH_PHONE=+966115207950
NABIH_PHONE_DISPLAY=011 520 7950
NABIH_EMAIL=info@muk3bat.com
